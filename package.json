{
  "name": "beatgrid",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "BeatGrid - Say the Word on Beat",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "postbuild": "node scripts/prerender.mjs --dist dist",
    "prerender": "node scripts/prerender.mjs --dist dist",
    "preview": "vite preview",
    "start": "node server/index.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "doctor": "react-doctor"
  },
  "dependencies": {
    "@google-cloud/storage": "7.19.0",
    "@google/genai": "1.50.1",
    "compression": "1.8.1",
    "cors": "2.8.6",
    "express": "5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "8.1.0",
    "i18next": "^25.7.3",
    "morgan": "1.10.1",
    "pino": "10.3.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^16.5.1",
    "react-router-dom": "7.14.2",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.2.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "esbuild": "0.28.0",
    "eslint": "10.2.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.5.0",
    "jsdom": "29.0.2",
    "knip": "6.7.0",
    "react-doctor": "^0.0.39",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "vite": "8.0.10",
    "vite-plugin-pwa": "1.2.0",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": "24.15.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowAny":[
        "react",
        "vite",
        "typescript"
      ]
    },
    "overrides": {
      "minimatch@<5.1.8": ">=5.1.8",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "rollup@<2.80.0": ">=2.80.0",
      "serialize-javascript@<7.0.5": ">=7.0.5",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "lodash@<=4.17.23": ">=4.18.0",
      "brace-expansion@<2.0.3": ">=2.0.3",
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "uuid@<14.0.0": ">=14.0.0",
      "qs@<=6.14.1": ">=6.14.2",
      "@tootallnate/once@<3.0.1": ">=3.0.1"
    }
  }
}